#!/usr/bin/env bash

set -euo pipefail

# Detect if running installed or from repo
if [ -d "/usr/local/lib/sysupdate" ]; then
    LIB_DIR="/usr/local/lib/sysupdate"
else
    BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    LIB_DIR="$BASE_DIR/lib"
fi

source "$LIB_DIR/core.sh"

main "$@"
